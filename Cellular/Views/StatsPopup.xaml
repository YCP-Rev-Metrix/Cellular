<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
               x:Class="Cellular.Views.StatsPopup"
               xmlns:vm="clr-namespace:Cellular.ViewModel"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border StrokeShape="RoundRectangle 10"
            Padding="20"
            BackgroundColor="White">

        <VerticalStackLayout Spacing="15" WidthRequest="300">

            <Label Text="Stats"
                   FontSize="22"
                   TextColor="Black"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="Gray" Opacity="0.5" WidthRequest="200"/>

            <!-- ======================== FILTER SUMMARY ======================== -->
            <Label Text="{Binding FilterSummary}"
                   FontSize="12"
                   TextColor="DimGray"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <BoxView HeightRequest="1" Color="Gray" Opacity="0.3" WidthRequest="200"/>

            <!-- ======================== GAME TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsGameType}" Spacing="8">
                <Label Text="Game Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />
                <Label Text="{Binding GamesPlayed, StringFormat='Games Played: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding GameAverage, StringFormat='Average: {0:N2}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding HighGame, StringFormat='High Game: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding LowGame, StringFormat='Low Game: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding StrikePercent, StringFormat='Strike%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding SparePercent, StringFormat='Spare%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding OpenPercent, StringFormat='Open%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
            </VerticalStackLayout>

            <!-- ======================== STRIKE TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsStrikeType}" Spacing="8">
                <Label Text="Strike Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />
                <Label Text="{Binding StrikeAttempts, StringFormat='Attempts: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding PocketCount, StringFormat='Pocket: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding HighPocketCount, StringFormat='High Pocket: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding LightPocketCount, StringFormat='Light Pocket: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding TotalPocketCount, StringFormat='Total Pocket: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding BNLDCount, StringFormat='BNLD: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding StrikePercent, StringFormat='Strike%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding CarryRate, StringFormat='Carry: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding PocketPercent, StringFormat='Pocket%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding CountAverage, StringFormat='Count Avg: {0:N1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
            </VerticalStackLayout>

            <!-- ======================== SPARE TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsSpareType}" Spacing="8">
                <Label Text="Spare Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />
                <Label Text="{Binding TotalSpares, StringFormat='Total Spares: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding SpareConversionRate, StringFormat='Conversion Rate: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding TotalOpens, StringFormat='Total Opens: {0}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding SparePercent, StringFormat='Spare%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding OpenPercent, StringFormat='Open%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding SplitPercent, StringFormat='Split%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
                <Label Text="{Binding WashoutPercent, StringFormat='Washout%: {0:P1}'}"
                       HorizontalOptions="Center" TextColor="Black" FontSize="16" />
            </VerticalStackLayout>

            <Button Text="Close"
                    Clicked="OnCloseClicked"
                    Margin="0,20,0,0"
                    HorizontalOptions="Center"
                    WidthRequest="120" />

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
