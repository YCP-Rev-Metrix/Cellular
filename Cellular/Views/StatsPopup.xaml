<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
               x:Class="Cellular.Views.StatsPopup"
               xmlns:vm="clr-namespace:Cellular.ViewModel"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border StrokeShape="RoundRectangle 10"
            Padding="10"
            BackgroundColor="White">

        <VerticalStackLayout Spacing="12" WidthRequest="280">

            <Label Text="Stats"
                   FontSize="22"
                   TextColor="Black"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="Gray" Opacity="0.5" />

            <!-- ======================== FILTER SUMMARY ======================== -->
            <Label Text="{Binding FilterSummary}"
                   FontSize="12"
                   TextColor="DimGray"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <BoxView HeightRequest="1" Color="Gray" Opacity="0.3" />

            <!-- ======================== GAME TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsGameType}" Spacing="8">
                <Label Text="Game Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />

                <Grid ColumnSpacing="6" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding GamesPlayed, StringFormat='Games: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding GameAverage, StringFormat='Average: {0:N2}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding HighGame, StringFormat='High: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding LowGame, StringFormat='Low: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="{Binding StrikePercent, StringFormat='Strike: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="{Binding SparePercent, StringFormat='Spare: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding OpenPercent, StringFormat='Open: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                </Grid>
            </VerticalStackLayout>

            <!-- ======================== STRIKE TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsStrikeType}" Spacing="8">
                <Label Text="Strike Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />

                <Grid ColumnSpacing="6" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding CountAverage, StringFormat='Count Avg: {0:N1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding StrikeAttempts, StringFormat='Attempts: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding TotalStrikes, StringFormat='Strikes: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding StrikePercent, StringFormat='Strike: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="{Binding PocketCount, StringFormat='Pocket: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="{Binding HighPocketCount, StringFormat='High Pocket: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="3" Grid.Column="0"
                           Text="{Binding LightPocketCount, StringFormat='Light Pocket: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="3" Grid.Column="1"
                           Text="{Binding TotalPocketCount, StringFormat='Total Pocket: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="4" Grid.Column="0"
                           Text="{Binding BNLDCount, StringFormat='B-N-L-D: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="4" Grid.Column="1"
                           Text="{Binding PocketPercent, StringFormat='Pocket: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    
                    <Label Grid.Row="5" Grid.Column="0"
                           Text="{Binding CarryPercent, StringFormat='Carry: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                   
                </Grid>
            </VerticalStackLayout>

            <!-- ======================== SPARE TYPE ======================== -->
            <VerticalStackLayout IsVisible="{Binding IsSpareType}" Spacing="8">
                <Label Text="Spare Stats"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="DarkSlateGray" HorizontalOptions="Center" />

                <Grid ColumnSpacing="6" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding TotalSpares, StringFormat='Total Spares: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding TotalOpens, StringFormat='Total Opens: {0}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding SpareConversionRate, StringFormat='Conv. Rate: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding SparePercent, StringFormat='Spare%: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="{Binding OpenPercent, StringFormat='Open%: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="{Binding SplitPercent, StringFormat='Split%: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />

                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding WashoutPercent, StringFormat='Washout%: {0:P1}'}"
                           HorizontalOptions="Center" TextColor="Black" FontSize="14" />
                </Grid>
            </VerticalStackLayout>

            <Button Text="Close"
                    Clicked="OnCloseClicked"
                    Margin="0,10,0,0"
                    HorizontalOptions="Center"
                    WidthRequest="120" />

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
