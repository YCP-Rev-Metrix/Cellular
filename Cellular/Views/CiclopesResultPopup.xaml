<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
               xmlns:views="clr-namespace:Cellular.Views"
               x:Class="Cellular.Views.CiclopesResultPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">
    <Border StrokeShape="RoundRectangle 14"
            Padding="0"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">
        <Grid x:Name="MainGrid"
              RowDefinitions="*,Auto">

            <!-- ===== BALL PANE (lane + stats + plots) ===== -->
            <Grid x:Name="BallPane" IsVisible="True"
                  Grid.Row="0"
                  ColumnDefinitions="160,*"
                  ColumnSpacing="0">
                <!-- Lane column -->
                <GraphicsView x:Name="BallPlotView"
                              Grid.Column="0"
                              Margin="0"/>

                <!-- Right column: hero stats + analysis, fills height -->
                <Grid Grid.Column="1" Padding="10,8,10,8"
                      RowDefinitions="Auto,*,10,Auto,*,10,Auto,*">

                    <!-- Section: Position -->
                    <Label Grid.Row="0" Text="POSITION"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           CharacterSpacing="1.5"
                           Margin="2,2,0,4"/>
                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*" ColumnSpacing="8"
                          RowDefinitions="*,*" RowSpacing="8">
                        <!-- Entry X -->
                        <Border Grid.Row="0" Grid.Column="0"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Primary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatEntryX" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="in" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="ENTRY X"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Exit X -->
                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Primary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatExitX" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="in" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="EXIT X"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Entry Angle -->
                        <Border Grid.Row="1" Grid.Column="0"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Primary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="1"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatEntryAngle" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="&#x00B0;" FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="Start" Margin="0,4,0,0"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="ENTRY ANGLE"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Breakpoint Dist -->
                        <Border Grid.Row="1" Grid.Column="1"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Primary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatBreakpoint" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="ft" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="BREAKPOINT"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Section: Kinematics -->
                    <Label Grid.Row="3" Text="KINEMATICS"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Secondary}"
                           CharacterSpacing="1.5"
                           Margin="2,0,0,4"/>
                    <Grid Grid.Row="4"
                          ColumnDefinitions="*,*" ColumnSpacing="8"
                          RowDefinitions="*,*" RowSpacing="8">
                        <!-- Avg Speed -->
                        <Border Grid.Row="0" Grid.Column="0"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Secondary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatAvgSpeed" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="mph" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="AVG SPEED"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Avg Accel -->
                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Secondary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatAvgAccel" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="ft/s&#x00B2;" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="AVG ACCEL"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Entry Speed -->
                        <Border Grid.Row="1" Grid.Column="0"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Secondary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatEntrySpeed" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="mph" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="ENTRY SPEED"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <!-- Exit Speed -->
                        <Border Grid.Row="1" Grid.Column="1"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" Color="{StaticResource Secondary}"/>
                                <Grid Grid.Column="1" RowDefinitions="*,Auto" Padding="6,6,6,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="2"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="StatExitSpeed" Text="--"
                                               FontSize="26" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                               VerticalTextAlignment="Center"/>
                                        <Label Text="mph" FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="End" Margin="0,0,0,5"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="EXIT SPEED"
                                           FontSize="9" FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Section: Analysis -->
                    <Label Grid.Row="6" Text="ANALYSIS"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}"
                           CharacterSpacing="1.5"
                           Margin="2,0,0,4"/>

                    <Border Grid.Row="7"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                            Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="#30000000" Offset="0,3" Radius="8" Opacity="0.35"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0" Color="{StaticResource Tertiary}"/>
                            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                                <Grid.GestureRecognizers>
                                    <SwipeGestureRecognizer Direction="Left" Swiped="OnPlotSwipedLeft"/>
                                    <SwipeGestureRecognizer Direction="Right" Swiped="OnPlotSwipedRight"/>
                                </Grid.GestureRecognizers>

                                <!-- Plot panels stacked, toggled via IsVisible -->
                                <Grid x:Name="PlotSpeedPanel" Grid.Row="0" IsVisible="True">
                                    <Label Text="Speed by Quarter (mph)" FontSize="9" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           Margin="8,4,0,0"
                                           VerticalOptions="Start"/>
                                    <GraphicsView x:Name="SpeedPlotView" Margin="0,18,0,0"/>
                                </Grid>
                                <Grid x:Name="PlotAccelPanel" Grid.Row="0" IsVisible="False">
                                    <Label Text="Accel by Quarter (ft/s&#x00B2;)" FontSize="9" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           Margin="8,4,0,0"
                                           VerticalOptions="Start"/>
                                    <GraphicsView x:Name="AccelPlotView" Margin="0,18,0,0"/>
                                </Grid>
                                <Grid x:Name="PlotLateralPanel" Grid.Row="0" IsVisible="False">
                                    <Label Text="Lateral Position (in)" FontSize="9" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           Margin="8,4,0,0"
                                           VerticalOptions="Start"/>
                                    <GraphicsView x:Name="LateralPlotView" Margin="0,18,0,0"/>
                                </Grid>

                                <!-- Plot dot navigation -->
                                <HorizontalStackLayout Grid.Row="1"
                                                       HorizontalOptions="Center"
                                                       Spacing="10"
                                                       Padding="0,4,0,8">
                                    <Border x:Name="PlotDot0"
                                            WidthRequest="8" HeightRequest="8"
                                            BackgroundColor="{StaticResource Secondary}"
                                            StrokeShape="RoundRectangle 4"
                                            StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlotDot0Clicked"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border x:Name="PlotDot1"
                                            WidthRequest="8" HeightRequest="8"
                                            BackgroundColor="{StaticResource Secondary}"
                                            StrokeShape="RoundRectangle 4"
                                            StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlotDot1Clicked"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border x:Name="PlotDot2"
                                            WidthRequest="8" HeightRequest="8"
                                            BackgroundColor="{StaticResource Secondary}"
                                            StrokeShape="RoundRectangle 4"
                                            StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlotDot2Clicked"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- ===== POSE PANE ===== -->
            <!-- PosePane: no swipe gestures here — pan is used for 3D camera rotation.
                 Use bottom dots to switch back to BallPane. -->
            <Grid x:Name="PosePane" IsVisible="False"
                  Grid.Row="0"
                  RowDefinitions="*,Auto"
                  Padding="10">

                <Border Grid.Row="0"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        Margin="0,40,0,0">
                    <views:CiclopesPoseView x:Name="PoseView"/>
                </Border>

                <!-- Loading overlay for pose data -->
                <Grid x:Name="PoseLoadingOverlay" Grid.Row="0"
                      BackgroundColor="{AppThemeBinding Light=#E0F4F7FA, Dark=#E0121A24}"
                      Margin="0,40,0,0"
                      IsVisible="True">
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12">
                        <ActivityIndicator IsRunning="True"
                                           Color="{StaticResource Secondary}"
                                           WidthRequest="48"
                                           HeightRequest="48"/>
                        <Label x:Name="PoseLoadingLabel"
                               Text="Loading pose estimation..."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,6,0,0"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="6">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}"
                            Padding="2,0"
                            VerticalOptions="Center">
                        <Picker x:Name="SpeedPicker"
                                WidthRequest="68"
                                HeightRequest="36"
                                FontSize="12"
                                TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                                SelectedIndexChanged="OnSpeedPickerChanged"
                                VerticalOptions="Center"/>
                    </Border>
                    <Slider x:Name="FrameSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="0"
                            Value="0"
                            ValueChanged="OnFrameSliderValueChanged"
                            VerticalOptions="Center"/>
                    <Button x:Name="PlayStopButton"
                            Grid.Column="2"
                            Text="&#x25B6;"
                            FontSize="20"
                            Clicked="OnPlayStopClicked"
                            WidthRequest="44"
                            HeightRequest="44"
                            Style="{StaticResource AccentButton}"/>
                </Grid>
            </Grid>

            <!-- Shot chip bar (multi-mode only) -->
            <HorizontalStackLayout x:Name="ShotChipBar"
                                   Grid.Row="0"
                                   IsVisible="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start"
                                   Spacing="6"
                                   Margin="54,14,54,0"/>

            <!-- Close button (top-left, overlaid) -->
            <Border x:Name="CloseButton"
                    Grid.Row="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Primary}"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="10,10,0,0">
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,2" Radius="6" Opacity="0.4"/>
                </Border.Shadow>
                <Label Text="&#x2715;" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseClicked"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- Page dots -->
            <HorizontalStackLayout Grid.Row="1"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="16"
                                   Padding="0,6,0,10">
                <Border x:Name="BallDot"
                        WidthRequest="12"
                        HeightRequest="12"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBallDotClicked"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="PoseDot"
                        WidthRequest="12"
                        HeightRequest="12"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPoseDotClicked"/>
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>

        </Grid>
    </Border>
</toolkit:Popup>
