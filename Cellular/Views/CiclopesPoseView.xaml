<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="Cellular.Views.CiclopesPoseView">
    <Grid BackgroundColor="#1a1a2e">
        <skia:SKCanvasView x:Name="SkeletonView"
                            PaintSurface="OnPaintSurface"
                            EnableTouchEvents="False"/>
        <!-- Transparent overlay to capture pan gestures without blocking SKGLView -->
        <Grid x:Name="GestureLayer" BackgroundColor="Transparent">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated"/>
            </Grid.GestureRecognizers>
        </Grid>
        <!-- Camera angle indicator -->
        <Label x:Name="CameraLabel"
               Text="Drag to rotate"
               FontSize="9"
               TextColor="#555580"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,6,4"/>
    </Grid>
</ContentView>
