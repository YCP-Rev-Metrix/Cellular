<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cellular.Stats"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Cellular.ViewModel">

    <Grid>

        <!-- Main content -->
        <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="20">

            <Image Source="logo.png" HeightRequest="185" Aspect="AspectFit" />

            <!-- Two columns of 4 pickers -->
            <Grid HorizontalOptions="Center" ColumnSpacing="20" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Rows: dates | session+event | game+ball | lanes+frame | house | statType | buttons -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /> <!-- house -->
                    <RowDefinition Height="Auto" /> <!-- statType -->
                    <RowDefinition Height="Auto" /> <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- Left column -->
                <DatePicker Grid.Row="0" Grid.Column="0"
                            x:Name="StartDate"
                            Date="{Binding StartDateDisplay, Mode=TwoWay}"
                            WidthRequest="140" />

                <!-- Session picker + clear -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="SessionPicker"
                            Title="Session"
                            ItemsSource="{Binding Sessions}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedSession}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Session" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Game # picker + clear -->
                <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="GamePicker"
                            Title="Game #"
                            ItemsSource="{Binding GamePositions}"
                            SelectedItem="{Binding SelectedGamePosition}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="GamePosition" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Lane picker + clear -->
                <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="LanesPicker"
                            Title="Lanes"
                            ItemsSource="{Binding Lanes}"
                            SelectedItem="{Binding SelectedLane}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Lane" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Right column -->
                <DatePicker Grid.Row="0" Grid.Column="1"
                            x:Name="EndDate"
                            Date="{Binding EndDateDisplay, Mode=TwoWay}"
                            WidthRequest="140" />

                <!-- Event picker + clear -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="EventPicker"
                            Title="Event"
                            ItemsSource="{Binding Events}"
                            ItemDisplayBinding="{Binding LongName}"
                            SelectedItem="{Binding SelectedEvent}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Event" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Ball picker + clear -->
                <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="BallPicker"
                            Title="Ball"
                            ItemsSource="{Binding Balls}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedBall}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Ball" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Frame picker + clear -->
                <HorizontalStackLayout Grid.Row="3" Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Picker x:Name="FramePicker"
                            Title="Frame"
                            ItemsSource="{Binding Frames}"
                            SelectedItem="{Binding SelectedFrame}"
                            WidthRequest="122" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Frame" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- House picker + clear -->
                <HorizontalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                       HorizontalOptions="Center" Spacing="4" Padding="0,10,0,0">
                    <Picker x:Name="HousePicker"
                            Title="House"
                            ItemsSource="{Binding Establishments}"
                            ItemDisplayBinding="{Binding NickName}"
                            SelectedItem="{Binding SelectedEstablishment}"
                            WidthRequest="185" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="Establishment" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- StatType picker + clear -->
                <HorizontalStackLayout Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                       HorizontalOptions="Center" Spacing="4" Padding="0,10,0,0">
                    <Picker x:Name="StatTypePicker"
                            Title="Stat Type"
                            ItemsSource="{Binding StatTypes}"
                            SelectedItem="{Binding SelectedStatType}"
                            WidthRequest="185" />
                    <Label Text="×" FontSize="18" TextColor="LightGray" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearPickerCommand}" CommandParameter="StatType" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Load Stats and Clear buttons side-by-side centered -->
                <HorizontalStackLayout Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                       HorizontalOptions="Center" Spacing="12" Padding="0,10,0,0">
                    <Button x:Name="LoadStatsButton" Text="Load Stats" WidthRequest="120" />
                    <Button Text="Clear" WidthRequest="120"
                            Command="{Binding ClearSessionCommand}" />
                </HorizontalStackLayout>
            </Grid>
        </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay — sits on top of all content while stats are being fetched -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Loading stats…"
                       TextColor="White"
                       FontSize="16"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
