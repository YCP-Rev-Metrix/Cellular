<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cellular.MainPage"
             xmlns:local="clr-namespace:Cellular.ViewModel"
             x:DataType="local:MainViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,32" Spacing="0">

            <!-- Header -->
            <Image Source="logo.png"
                   HeightRequest="110"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   Margin="0,0,0,12"
                   SemanticProperties.Description="RevMetrix Logo" />

            <Label Text="RevMetrix"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"
                   Margin="0,0,0,4" />

            <!-- Welcome row — shown when logged in -->
            <HorizontalStackLayout x:Name="welcomeRow"
                                   HorizontalOptions="Center"
                                   Spacing="4"
                                   IsVisible="False"
                                   Margin="0,4,0,28">
                <Label x:Name="welcome"
                       Text="Welcome back,"
                       FontSize="15"
                       TextColor="{StaticResource Gray400}"
                       VerticalOptions="Center" />
                <Label x:Name="user"
                       Text="{Binding FirstName}"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Secondary}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Logged-out panel -->
            <Border x:Name="loggedOutPanel"
                    IsVisible="True"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="24"
                    Margin="0,8,0,0">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Get Started"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"
                           Margin="0,0,0,4" />

                    <Button x:Name="login"
                            Text="Sign In"
                            Clicked="OnLoginClicked"
                            HorizontalOptions="Fill" />

                    <Button x:Name="register"
                            Text="Register"
                            Clicked="OnRegisterClicked"
                            HorizontalOptions="Fill"
                            Style="{StaticResource AccentButton}" />

                    <Button x:Name="guest"
                            Text="Continue as Guest"
                            Clicked="OnGuestClicked"
                            HorizontalOptions="Fill"
                            Style="{StaticResource AccentButton}"
                            Opacity="0.6" />

                </VerticalStackLayout>
            </Border>

            <!-- Logged-in nav grid -->
            <Grid x:Name="loggedInPanel"
                  IsVisible="False"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12"
                  Margin="0,0,0,0">

                <Button x:Name="arsenal"
                        Grid.Row="0" Grid.Column="0"
                        Text="Ball Arsenal"
                        Clicked="OnArsenalClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="EventList"
                        Grid.Row="0" Grid.Column="1"
                        Text="Event List"
                        Clicked="OnEventListClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="bluetooth"
                        Grid.Row="1" Grid.Column="0"
                        Text="Bluetooth"
                        Clicked="OnBluetoothClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="video"
                        Grid.Row="1" Grid.Column="1"
                        Text="Video"
                        Clicked="OnVideoClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="establishment"
                        Grid.Row="2" Grid.Column="0"
                        Text="Establishments"
                        Clicked="OnEstablishmentClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="databaseVisualizer"
                        Grid.Row="2" Grid.Column="1"
                        Text="SQL Database"
                        Clicked="OnDatabaseVisualizerClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="API"
                        Grid.Row="3" Grid.Column="0"
                        Text="API Test"
                        Clicked="OnAPIClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="account"
                        Grid.Row="3" Grid.Column="1"
                        Text="Account"
                        Clicked="OnAccountClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="BlankPage"
                        Grid.Row="4" Grid.Column="0"
                        Text="Smart Watch"
                        Clicked="OnBlankPageClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

                <Button x:Name="ciclopesTest"
                        Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                        Text="Ciclopes Test"
                        Clicked="OnCiclopesTestClicked"
                        HeightRequest="72"
                        Style="{StaticResource AccentButton}" />

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
