<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cellular.Video2"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="MmsConnectionToolbarItem"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnMmsConnectionIconClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="logo.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="RevMetrix Bowling Ball Logo" />

            <Picker x:Name="ResolutionPicker"
                Title="Select Resolution"
                Grid.Row="0"
                BackgroundColor="LightSlateGray"
                SelectedIndexChanged="ResolutionPicker_SelectedIndexChanged" />

            <toolkit:CameraView
                x:Name="cameraView"
                Grid.Row="0"
                WidthRequest="300"
                HeightRequest="400"
                HorizontalOptions="Center"
                SelectedCamera="{Binding SelectedCamera}"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Button x:Name="RecordBtn"
                    Text="Record"
                    Clicked="OnRecordClicked"
                    WidthRequest="90"
                    IsEnabled="False"
                    BackgroundColor="Gray"/>
                <Button x:Name="UseCiclopesBtn"
                    Text="Use Ciclopes"
                    Clicked="OnUseCiclopesClicked"
                    IsVisible="False"
                    WidthRequest="90"
                    HeightRequest="90"
                    BackgroundColor="#9880e5"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
